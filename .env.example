# Database
DATABASE_URL=postgresql+asyncpg://wiki_genres:wiki_genres@localhost:5433/wiki_genres

# HTTP client identity (required by Wikimedia ToU — set this to a real contact)
WIKI_USER_AGENT=wiki-genres/0.0.1 (https://github.com/koopakondra/wiki-genres-project; you@example.com)

# API
API_HOST=0.0.0.0
API_PORT=8080

# Admin token for write endpoints (POST /admin/...). Generate with `openssl rand -hex 32`.
ADMIN_TOKEN=

# Crawler tunables
CRAWLER_CONCURRENCY=4
CRAWLER_REQUEST_INTERVAL_MS=250
CRAWLER_CACHE_DIR=./.cache

# Sync worker
EVENTSTREAM_URL=https://stream.wikimedia.org/v2/stream/recentchange
EVENTSTREAM_RECONNECT_DELAY_MS=2000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
